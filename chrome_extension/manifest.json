{
  "manifest_version": 3,
  "name": "네이버 경쟁사 모니터링",
  "version": "4.2",
  "description": "네이버 스마트스토어 경쟁사 재고를 자동 수집합니다",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": [
    "*://*.naver.com/*",
    "https://*.up.railway.app/*",
    "https://*.railway.app/*"
  ],
  "content_scripts": [{
    "matches": ["*://*.smartstore.naver.com/*", "*://brand.naver.com/*"],
    "js": ["content.js"],
    "run_at": "document_start",
    "world": "MAIN"
  }],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
